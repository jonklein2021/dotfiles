alias ".."="cd .."
alias "..."="cd ../.."
alias "...."="cd ../../.."
alias "....."="cd ../../../.."

# Git
alias g='git'
alias ga='git add'
alias gb='git branch'
alias gbdm='git branch --merged | grep -v '^\*' | xargs -n 1 git branch -d' # deletes merged branches
alias gca='git commit --amend --date=now'
alias gcane='git commit --amend --no-edit --date=now'
alias gcfg='git config'
alias gcl='git clone'
alias gcm='git commit -m'
alias gco='git checkout'
alias gd='git diff'
alias gf='git fetch'
alias gl='git log'
alias glo='git log --pretty=format:"%C(yellow)%h %Cblue%ad %Cgreen%an %Creset%s" --date=short'
alias glg='git log --graph'
alias gm='git merge'
alias gp='git push'
alias gpl='git pull'
alias gplo='git pull origin HEAD'
alias gplr='git pull --rebase'
alias gpo='git push origin HEAD'
alias grb='git rebase'
alias grbc='git rebase --continue'
alias grh='git reset'
alias grm='git remote'
alias grs='git restore'
alias gs='git status'
alias gsh='git show'
alias gst='git stash'
alias gsw='git switch'

# Tmux
alias tm='tmux'
alias tmat='tmux attach -t'
alias tmns='tmux new -s'
alias tmls='tmux ls'
alias tmkt='tmux kill-session -t'
alias tmks='tmux kill-server'

# Meson
alias mc='meson compile'
alias ms='meson setup'
alias msb='meson setup build'
alias msbr='meson setup build --reconfigure'

# Add an "alert" alias for long running commands.  Use like so:
#   sleep 10; alert
alias alert='notify-send --urgency=low -i "$([ $? = 0 ] && echo terminal || echo error)" "$(history|tail -n1|sed -e '\''s/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//'\'')"'

# System Monitoring
alias htop='htop'
alias dush='du -sh *'
alias meminfo="free -h"

# Networking
alias myip="curl ifconfig.me"
alias ports="netstat -tulanp | grep LISTEN"
alias pingg="ping google.com"

# Daily Utilities
alias _="sudo "
alias mkd='mkdir -p'
alias ..ln='ln -s'
alias cpr='cp -r'
alias clup='sudo apt update && sudo apt upgrade -y'
alias cls="clear"

# Other Programs
alias nv="nvim"
alias v="vim"
alias y="yazi"

